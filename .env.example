# Cloudflare Pages 环境变量配置示例
# 复制此文件内容到 Cloudflare Pages 的环境变量设置中

# 必需的环境变量 - 在 Cloudflare Pages 项目设置中配置

# Cloudflare Turnstile Site Key (公钥)
# 获取方式: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=0x4AAAAAADTy6YTSxcziFVXR

# Cloudflare Turnstile Secret Key (私钥) 
# 获取方式: 在同一 Turnstile 控制台页面
TURNSTILE_SECRET_KEY=your_secret_key_here

# 允许访问 API 的域名列表 (逗号分隔)
# 替换为你的实际域名
ALLOWED_ORIGINS=https://swabox.cc.cd,https://www.swabox.cc.cd

# 本地开发环境变量 (可选 - 仅用于本地开发)
# 在本地 .env 文件中使用

# 开发环境 Site Key (可选 - 用于本地开发)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADTy6YTSxcziFVXR

# 强制启用安全验证 (可选 - 开发环境测试用)
# 设置为 'true' 时，开发环境也会进行完整的安全验证
VITE_ENABLE_SECURITY=false